<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lights_brown"
    tools:context=".RegisterActivity">

    <ImageView
        android:layout_width="330dp"
        android:layout_height="330dp"
        android:layout_marginEnd="-40dp"
        android:layout_marginBottom="-40dp"
        android:src="@drawable/registering_img"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/text_register_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="90dp"
        android:fontFamily="@font/font_five"
        android:text="@string/register"
        android:textAlignment="center"
        android:textAllCaps="false"
        android:textFontWeight="800"
        android:textSize="69sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.melikash98.editify.CustomInputEdit
        android:id="@+id/email_register"
        android:layout_width="300dp"
        android:singleLine="true"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:textFontWeight="800"
        app:activeBackground="@drawable/input_active"
        app:hintActiveColor="@color/brown"
        app:hintBackgroundColor="@color/lights_brown"
        app:hintColor="@color/gray"
        app:hintFamily="@font/font_three"
        app:hintIcon="@drawable/email"
        app:hintSize="16sp"
        app:hintText="@string/email"
        app:inactiveBackground="@drawable/input_inactive"
        app:inputColor="@color/black"
        app:inputFamily="@font/font_three"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_register_title"
        app:textColor="@color/black"
        tools:ignore="MissingConstraints" />
    <com.melikash98.editify.CustomInputEdit
        android:id="@+id/userName_register"
        android:layout_width="300dp"
        android:singleLine="true"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:textFontWeight="800"
        app:activeBackground="@drawable/input_active"
        app:hintActiveColor="@color/brown"
        app:hintBackgroundColor="@color/lights_brown"
        app:hintColor="@color/gray"
        app:hintFamily="@font/font_three"
        app:hintIcon="@drawable/user_name_icon"
        app:hintSize="16sp"
        app:hintText="@string/user_name"
        app:inactiveBackground="@drawable/input_inactive"
        app:inputColor="@color/black"
        app:inputFamily="@font/font_three"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/email_register"
        app:textColor="@color/black"
        tools:ignore="MissingConstraints" />
    <com.melikash98.editify.CustomInputEdit
        android:id="@+id/pass_register"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:textFontWeight="800"
        app:activeBackground="@drawable/input_active"
        app:hintActiveColor="@color/brown"
        app:hintBackgroundColor="@color/lights_brown"
        app:hintColor="@color/gray"
        app:hintFamily="@font/font_three"
        app:hintIcon="@drawable/pass_account"
        app:hintSize="16sp"
        app:hintText="@string/password"
        app:inactiveBackground="@drawable/input_inactive"
        app:inputColor="@color/black"
        app:inputFamily="@font/font_three"
        app:inputType="textPassword"
        android:layout_marginTop="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/userName_register"
        app:passHide="@drawable/hide_pass"
        app:passShow="@drawable/show_pass"
        app:textColor="@color/black"
        tools:ignore="MissingConstraints" />
    <com.example.loadinganimation.LoadingAnimation
        android:id="@+id/loadingAnim"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:elevation="10dp"
        app:barType="@drawable/bouncy_balls"
        app:boldText="false"
        app:enlarge="5"
        app:textColor="@color/purple_500"
        app:textSize="15sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/pass_register"
        app:layout_constraintBottom_toTopOf="@id/registerBtn"/>
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/registerBtn"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/pass_register"
        android:layout_marginTop="70dp"
        android:text="@string/register"
        android:textSize="20sp"
        android:elevation="10dp"
        android:textColor="@color/blue_white"
        android:textAllCaps="false"
        android:fontFamily="@font/font_four"
        android:textFontWeight="800"
        android:background="@drawable/bg_btns"/>
    <ImageView
        android:id="@+id/line_sign_up"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:backgroundTint="@color/color_two"
        android:background="@drawable/line_progress"
        android:layout_marginTop="5dp"
        app:layout_constraintTop_toBottomOf="@id/registerBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/line_sign_up"
        android:layout_marginTop="5dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:text="@string/account_have"
            android:textAlignment="center"
            android:textColor="@color/brown"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:fontFamily="@font/font_three"
            android:textFontWeight="900"
            android:id="@+id/text_one_forgot"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/text_one_forgot"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="10dp"
            android:text="@string/signUP"
            android:textAlignment="center"
            android:textColor="@color/color_one"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:fontFamily="@font/font_three"
            android:textFontWeight="900"
            android:id="@+id/logInBtn"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>