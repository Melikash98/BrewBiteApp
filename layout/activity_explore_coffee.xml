<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ExploreCoffeeActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bar_explore"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:background="@drawable/bg_bar_explore"
        tools:ignore="MissingConstraints">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/profile_explore"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginStart="30dp"
            android:src="@drawable/profile"
            app:civ_border_overlay="true"
            app:layout_constraintBottom_toTopOf="@id/search_explore"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:orientation="vertical"
            android:padding="0dp"
            app:layout_constraintBottom_toBottomOf="@id/profile_explore"
            app:layout_constraintStart_toEndOf="@id/profile_explore"
            app:layout_constraintTop_toTopOf="@id/profile_explore">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:fontFamily="@font/font_welcome"
                android:text="@string/welcome"
                android:textAllCaps="false"
                android:textColor="@color/blue_white"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/userName_explore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/font_two"
                android:letterSpacing=".01"
                android:text="Melika_sh_98"
                android:textAllCaps="false"
                android:textColor="@color/blue_white"
                android:textSize="16sp" />
        </LinearLayout>


        <com.melikash98.editify.CustomInputEdit
            android:id="@+id/search_explore"
            android:layout_width="350dp"
            android:singleLine="true"
            android:layout_height="80dp"
            app:buttonMode="true"
            android:layout_marginTop="50dp"
            android:layout_marginBottom="40dp"
            android:textFontWeight="800"
            app:activeBackground="@drawable/input_active_search"
            app:hintActiveColor="@color/blue_white"
            app:hintBackgroundColor="@color/dark_brown"
            app:hintColor="@color/blue_white"
            app:hintFamily="@font/font_three"
            app:hintIcon="@drawable/search"
            app:hintSize="16sp"
            app:hintText="@string/search"
            app:inactiveBackground="@drawable/input_inactive_search"
            app:inputColor="@color/blue_white"
            app:inputFamily="@font/font_three"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:textColor="@color/blue_white"
            tools:ignore="MissingConstraints" />

       <androidx.constraintlayout.widget.ConstraintLayout
           android:id="@+id/notificationBtn"
           android:layout_width="40dp"
           android:layout_height="40dp"
           app:layout_constraintBottom_toBottomOf="@id/profile_explore"
           app:layout_constraintEnd_toEndOf="parent"
           app:layout_constraintTop_toTopOf="@id/profile_explore"
           android:layout_marginEnd="30dp">
           <androidx.constraintlayout.widget.ConstraintLayout
               android:layout_width="20dp"
               android:layout_height="20dp"
               android:background="@drawable/loading_back_circle"
               app:layout_constraintEnd_toEndOf="parent"
               app:layout_constraintTop_toTopOf="parent"
               android:backgroundTint="@color/gold"
               android:elevation="30dp">
               <TextView
                   android:id="@+id/notifNumber"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:text="0"
                   android:textColor="@color/dark_red"
                   android:textSize="16sp"
                   app:layout_constraintStart_toStartOf="parent"
                   app:layout_constraintEnd_toEndOf="parent"
                   app:layout_constraintTop_toTopOf="parent"
                   app:layout_constraintBottom_toBottomOf="parent"
                   android:textFontWeight="800"
                   android:fontFamily="@font/font_three"/>
           </androidx.constraintlayout.widget.ConstraintLayout>
           <ImageView
               android:id="@+id/notification_explore"
               android:layout_width="28dp"
               android:layout_height="28dp"
               android:background="@drawable/notification"
               android:backgroundTint="@color/blue_white"
               app:layout_constraintStart_toStartOf="parent"
               app:layout_constraintEnd_toEndOf="parent"
               app:layout_constraintTop_toTopOf="parent"
               app:layout_constraintBottom_toBottomOf="parent"/>
       </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.smarteist.autoimageslider.SliderView
        android:id="@+id/banner_slider"
        android:layout_width="350dp"
        android:layout_height="200dp"
        android:layout_marginTop="-15dp"
        android:padding="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bar_explore"
        app:sliderAnimationDuration="600"
        app:sliderAutoCycleDirection="back_and_forth"
        app:sliderAutoCycleEnabled="true"
        app:sliderIndicatorAnimationDuration="600"
        app:sliderIndicatorGravity="center_horizontal|bottom"
        app:sliderIndicatorMargin="25dp"
        app:sliderIndicatorOrientation="horizontal"
        app:sliderIndicatorPadding="3dp"
        app:sliderIndicatorRadius="2dp"
        app:sliderIndicatorSelectedColor="@color/dark_brown"
        app:sliderIndicatorUnselectedColor="@color/light_gray"
        app:sliderScrollTimeInSec="1"
        app:sliderStartAutoCycle="true" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/CategoriesRec"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:layout_marginTop="5dp"
        android:layout_marginEnd="40dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/banner_slider" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginVertical="20dp"
        android:paddingBottom="250dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/CategoriesRec">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="200dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="200dp">

                <TextView
                    android:id="@+id/popular_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="30dp"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/font_title_explore"
                    android:text="@string/popular_items"
                    android:textAlignment="center"
                    android:textAllCaps="false"
                    android:textColor="@color/dark_brown"
                    android:textFontWeight="800"
                    android:textSize="24sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <TextView
                    android:id="@+id/popularBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="30dp"
                    android:fontFamily="@font/font_title_explore"
                    android:text="@string/more"
                    android:textAlignment="center"
                    android:textAllCaps="false"
                    android:textColor="@color/dark_red"
                    android:textFontWeight="800"
                    android:textSize="18sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/popular_title"
                    app:layout_constraintBottom_toBottomOf="@id/popular_title"/>


                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/popularRec"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginEnd="20dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/popular_title" />

                <TextView
                    android:id="@+id/best_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="30dp"
                    android:layout_marginTop="20dp"
                    android:fontFamily="@font/font_title_explore"
                    android:text="@string/best_items"
                    android:textAlignment="center"
                    android:textAllCaps="false"
                    android:textColor="@color/dark_brown"
                    android:textFontWeight="800"
                    android:textSize="24sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/popularRec" />
                <TextView
                    android:id="@+id/bestBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/font_title_explore"
                    android:text="@string/more"
                    android:textAlignment="center"
                    android:textAllCaps="false"
                    android:textColor="@color/dark_red"
                    android:textFontWeight="800"
                    android:textSize="18sp"
                    app:layout_constraintEnd_toEndOf="@id/popularBtn"
                    app:layout_constraintTop_toTopOf="@id/best_title"
                    app:layout_constraintBottom_toBottomOf="@id/best_title"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/bestRec"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginEnd="20dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/best_title" />

                <TextView
                    android:id="@+id/new_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="30dp"
                    android:layout_marginTop="20dp"
                    android:fontFamily="@font/font_title_explore"
                    android:text="@string/news_items"
                    android:textAlignment="center"
                    android:textAllCaps="false"
                    android:textColor="@color/dark_brown"
                    android:textFontWeight="800"
                    android:textSize="24sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/bestRec" />
                <TextView
                    android:id="@+id/newsBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/font_title_explore"
                    android:text="@string/more"
                    android:textAlignment="center"
                    android:textAllCaps="false"
                    android:textColor="@color/dark_red"
                    android:textFontWeight="800"
                    android:textSize="18sp"
                    app:layout_constraintEnd_toEndOf="@id/popularBtn"
                    app:layout_constraintTop_toTopOf="@id/new_title"
                    app:layout_constraintBottom_toBottomOf="@id/new_title"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/newsRec"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginEnd="20dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/new_title" />

                <TextView
                    android:id="@+id/coffee_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="30dp"
                    android:layout_marginTop="20dp"
                    android:fontFamily="@font/font_title_explore"
                    android:text="@string/coffee_items"
                    android:textAlignment="center"
                    android:textAllCaps="false"
                    android:textColor="@color/dark_brown"
                    android:textFontWeight="800"
                    android:textSize="24sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/newsRec" />
                <TextView
                    android:id="@+id/coffeeBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/font_title_explore"
                    android:text="@string/more"
                    android:textAlignment="center"
                    android:textAllCaps="false"
                    android:textColor="@color/dark_red"
                    android:textFontWeight="800"
                    android:textSize="18sp"
                    app:layout_constraintEnd_toEndOf="@id/popularBtn"
                    app:layout_constraintTop_toTopOf="@id/coffee_title"
                    app:layout_constraintBottom_toBottomOf="@id/coffee_title"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/coffee_Rec"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginEnd="20dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/coffee_title" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
    </ScrollView>

    <com.melikash98.morphnavbar.MorphNavBar
        android:id="@+id/morphExplore"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:lbv_barColor="@color/white"
        app:lbv_selectedColor="@color/dark_brown"
        app:lbv_unselectedColor="@color/gray"
        app:lbv_activeIconColor="@color/blue_white"
        app:lbv_inactiveIconColor="@color/gray"
        app:lbv_showLabelOnlyOnSelected="true"
        app:lbv_barHeight="85dp"
        app:lbv_labelTextSize="12sp"
        app:lbv_labelFontFamily="@font/font_three"
        app:lbv_badgeBackgroundColor="@color/dark_brown"
        app:lbv_badgeTextColor="@color/white"
        app:lbv_badgeTextSize="8sp"
        app:lbv_itemIconSize="28dp"
        app:lbv_barSideMargin="0dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>