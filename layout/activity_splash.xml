<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SplashActivity">
    <pl.droidsonroids.gif.GifImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/splach_gif"
        android:id="@+id/splash_gift"/>
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:alpha=".4"/>
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:src="@drawable/name_app_splash"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="50dp"
        android:id="@+id/logo_name_app"/>
    <TextView
        android:id="@+id/text_description_splash"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:text="@string/splash_description"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="155dp"
        android:textColor="@color/blue_white"
        android:textFontWeight="900"
        android:textSize="24sp"
        android:letterSpacing="0.0"
        android:textAllCaps="false"
        android:textAlignment="center"
        android:justificationMode="inter_character"
        android:fontFamily="@font/splash_font"/>

    <ProgressBar
        android:id="@+id/progress_splash"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:backgroundTint="@color/color_one"
        android:foregroundTint="@color/color_one"
        android:indeterminateTint="@color/color_one"
        android:progressTint="@color/color_one"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_description_splash" />

</androidx.constraintlayout.widget.ConstraintLayout>