<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_cat_ex"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    android:padding="5dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/real_categories_card"
        android:visibility="visible">
        <ImageView
            android:id="@+id/bac_cat_ex"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:background="@drawable/circle_cat_back"
            app:civ_border_width="2dp"
            app:layout_constraintStart_toStartOf="@id/name_cat_ex"
            app:layout_constraintEnd_toEndOf="@id/name_cat_ex"
            app:layout_constraintBottom_toTopOf="@id/name_cat_ex"
            app:layout_constraintTop_toTopOf="parent"
            app:civ_border_color="#FF000000" />
        <ImageView
            android:id="@+id/img_cat_ex"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/bread"
            android:scaleType="fitCenter"
            app:civ_border_width="2dp"
            app:layout_constraintEnd_toEndOf="@id/bac_cat_ex"
            app:layout_constraintTop_toTopOf="@id/bac_cat_ex"
            app:layout_constraintBottom_toBottomOf="@id/bac_cat_ex"
            app:layout_constraintStart_toStartOf="@id/bac_cat_ex"/>
        <TextView
            android:id="@+id/name_cat_ex"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cat_name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/bac_cat_ex"
            android:layout_marginTop="8dp"
            android:textColor="@color/black"
            android:fontFamily="@font/font_cat"
            android:textSize="15sp"
            android:textFontWeight="700"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/shimmer_categories"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <View
                android:id="@+id/img_cat_loading_ex"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:background="@drawable/loading_back_circle"
                android:cropToPadding="true"
                android:scaleType="centerCrop"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:id="@+id/location_items_loading_ex"
                android:layout_width="60dp"
                android:layout_height="15dp"
                android:layout_marginStart="5dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/loading_back_re"
                android:cropToPadding="true"
                android:scaleType="centerCrop"
                app:layout_constraintStart_toStartOf="@id/img_cat_loading_ex"
                app:layout_constraintEnd_toEndOf="@id/img_cat_loading_ex"
                app:layout_constraintTop_toBottomOf="@id/img_cat_loading_ex" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.facebook.shimmer.ShimmerFrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>