<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".NotesActivity"
    android:background="@color/white">
    <TextView
        android:id="@+id/text_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="About BrewBite"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="30dp"
        android:layout_marginStart="30dp"
        android:textColor="@color/dark_red"
        android:textFontWeight="800"
        android:textAlignment="center"
        android:textSize="20sp"
        android:fontFamily="@font/font_two"/>
    <TextView
        android:id="@+id/text_about"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:text="@string/about_app"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_title"
        android:layout_marginTop="20dp"
        android:layout_marginStart="30dp"
        android:textColor="@color/dark_brown"
        android:textFontWeight="800"
        android:textAlignment="textStart"
        android:justificationMode="inter_character"
        android:textSize="16sp"
        android:fontFamily="@font/font_three"/>
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginVertical="20dp"
        android:paddingBottom="250dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
       app:layout_constraintTop_toBottomOf="@id/text_about">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="200dp">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="200dp">
                <TextView
                    android:id="@+id/what_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/what"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:layout_marginTop="30dp"
                    android:layout_marginStart="30dp"
                    android:textColor="@color/dark_red"
                    android:textFontWeight="800"
                    android:textAlignment="center"
                    android:textSize="20sp"
                    android:fontFamily="@font/font_two"/>
                <TextView
                    android:visibility="gone"
                    android:id="@+id/text_what"
                    android:layout_width="350dp"
                    android:layout_height="wrap_content"
                    android:text="@string/what_app"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/what_title"
                    android:layout_marginTop="20dp"
                    android:layout_marginStart="30dp"
                    android:textColor="@color/dark_brown"
                    android:textFontWeight="800"
                    android:textAlignment="textStart"
                    android:justificationMode="inter_character"
                    android:textSize="16sp"
                    android:fontFamily="@font/font_three"/>
                <TextView
                    android:id="@+id/ordering_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ordering"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_what"
                    android:layout_marginTop="30dp"
                    android:layout_marginStart="30dp"
                    android:textColor="@color/dark_red"
                    android:textFontWeight="800"
                    android:textAlignment="center"
                    android:textSize="20sp"
                    android:fontFamily="@font/font_two"/>
                <TextView
                    android:visibility="gone"
                    android:id="@+id/text_ordering"
                    android:layout_width="350dp"
                    android:layout_height="wrap_content"
                    android:text="@string/what_app"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/ordering_title"
                    android:layout_marginTop="20dp"
                    android:layout_marginStart="30dp"
                    android:textColor="@color/dark_brown"
                    android:textFontWeight="800"
                    android:textAlignment="textStart"
                    android:justificationMode="inter_character"
                    android:textSize="16sp"
                    android:fontFamily="@font/font_three"/>
                <TextView
                    android:id="@+id/your_account_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/your_account"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_ordering"
                    android:layout_marginTop="30dp"
                    android:layout_marginStart="30dp"
                    android:textColor="@color/dark_red"
                    android:textFontWeight="800"
                    android:textAlignment="center"
                    android:textSize="20sp"
                    android:fontFamily="@font/font_two"/>
                <TextView
                    android:visibility="gone"
                    android:id="@+id/text_your_account"
                    android:layout_width="350dp"
                    android:layout_height="wrap_content"
                    android:text="@string/your_account_app"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/your_account_title"
                    android:layout_marginTop="20dp"
                    android:layout_marginStart="30dp"
                    android:textColor="@color/dark_brown"
                    android:textFontWeight="800"
                    android:textAlignment="textStart"
                    android:justificationMode="inter_character"
                    android:textSize="16sp"
                    android:fontFamily="@font/font_three"/>
                <TextView
                    android:id="@+id/built_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/built"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_your_account"
                    android:layout_marginTop="30dp"
                    android:layout_marginStart="30dp"
                    android:textColor="@color/dark_red"
                    android:textFontWeight="800"
                    android:textAlignment="center"
                    android:textSize="20sp"
                    android:fontFamily="@font/font_two"/>
                <TextView
                    android:visibility="gone"
                    android:id="@+id/text_built"
                    android:layout_width="350dp"
                    android:layout_height="wrap_content"
                    android:text="@string/built_app"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/built_title"
                    android:layout_marginTop="20dp"
                    android:layout_marginStart="30dp"
                    android:textColor="@color/dark_brown"
                    android:textFontWeight="800"
                    android:textAlignment="textStart"
                    android:justificationMode="inter_character"
                    android:textSize="16sp"
                    android:fontFamily="@font/font_three"/>
                <TextView
                    android:visibility="gone"
                    android:id="@+id/MorphNavBar_title"
                    android:layout_width="350dp"
                    android:layout_height="wrap_content"
                    android:text="@string/MorphNavBar"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/text_built"
                    android:layout_marginTop="20dp"
                    android:layout_marginStart="30dp"
                    android:textColor="@color/dark_brown"
                    android:textFontWeight="800"
                    android:textAlignment="textStart"
                    android:justificationMode="inter_character"
                    android:textSize="16sp"
                    android:fontFamily="@font/font_three"/>
                <TextView
                    android:visibility="gone"
                    android:id="@+id/Editify_title"
                    android:layout_width="350dp"
                    android:layout_height="wrap_content"
                    android:text="@string/Editify"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/MorphNavBar_title"
                    android:layout_marginTop="20dp"
                    android:layout_marginStart="30dp"
                    android:textColor="@color/dark_brown"
                    android:textFontWeight="800"
                    android:textAlignment="textStart"
                    android:justificationMode="inter_character"
                    android:textSize="16sp"
                    android:fontFamily="@font/font_three"/>
                <TextView
                    android:visibility="gone"
                    android:id="@+id/end_title"
                    android:layout_width="350dp"
                    android:layout_height="wrap_content"
                    android:text="@string/end"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/Editify_title"
                    android:layout_marginTop="20dp"
                    android:layout_marginStart="30dp"
                    android:textColor="@color/dark_brown"
                    android:textFontWeight="800"
                    android:textAlignment="textStart"
                    android:justificationMode="inter_character"
                    android:textSize="16sp"
                    android:fontFamily="@font/font_three"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
    </ScrollView>
    <com.melikash98.morphnavbar.MorphNavBar
        android:id="@+id/morphNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:lbv_barColor="@color/white"
        app:lbv_selectedColor="@color/dark_brown"
        app:lbv_unselectedColor="@color/gray"
        app:lbv_activeIconColor="@color/blue_white"
        app:lbv_inactiveIconColor="@color/gray"
        app:lbv_showLabelOnlyOnSelected="true"
        app:lbv_barHeight="85dp"
        app:lbv_labelTextSize="12sp"
        app:lbv_labelFontFamily="@font/font_three"
        app:lbv_badgeBackgroundColor="@color/dark_brown"
        app:lbv_badgeTextColor="@color/white"
        app:lbv_badgeTextSize="8sp"
        app:lbv_itemIconSize="28dp"
        app:lbv_barSideMargin="0dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>