<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="5dp"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    android:layout_margin="5dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/item_notif_message_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginStart="20dp">
            <ImageView
                android:id="@+id/iconNotif"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:tint="@color/dark_green"
                android:src="@drawable/arrow_right_notif"
                tools:ignore="UseAppTint" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Type"
                android:textFontWeight="800"
                android:textDirection="ltr"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:fontFamily="@font/font_three"
                android:id="@+id/typeNotif"
                app:layout_constraintTop_toTopOf="@id/iconNotif"
                app:layout_constraintBottom_toBottomOf="@id/iconNotif"
                app:layout_constraintStart_toEndOf="@id/iconNotif"
                android:layout_marginStart="10dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/messageIdLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginStart="10dp"
            app:layout_constraintStart_toStartOf="@id/item_notif_message_btn"
            app:layout_constraintTop_toBottomOf="@id/item_notif_message_btn">
            <TextView
                android:visibility="gone"
                android:layout_width="350dp"
                android:layout_height="wrap_content"
                android:text="message"
                android:textFontWeight="800"
                android:textDirection="ltr"
                android:textColor="@color/dark_red"
                android:textSize="14sp"
                android:fontFamily="@font/font_three"
                android:id="@+id/messageNotif"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <androidx.appcompat.widget.AppCompatButton
                android:visibility="gone"
                android:id="@+id/sendNewVerifyBtn"
                android:layout_width="250dp"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:layout_height="40dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/messageNotif"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_btns"
                android:text="@string/send_new_verify_notif"
                android:textSize="12sp"
                android:fontFamily="@font/font_welcome"
                android:textColor="@color/blue_white"
                android:textFontWeight="900"
                android:textAlignment="center"
                android:textAllCaps="false"
                android:letterSpacing=".1"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginBottom="10dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>