<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    android:paddingBottom="30dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    android:background="@drawable/bg_dialog_popup">
    <ImageView
        android:id="@+id/linImg"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/line_progress"
        android:tint="@color/dark_brown"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="5dp"
        tools:ignore="UseAppTint" />
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/birthdayBtn"
        android:layout_width="100dp"
        android:layout_height="40dp"
        android:text="@string/set"
        android:textFontWeight="800"
        android:textSize="16sp"
        android:background="@drawable/bg_btns"
        android:textColor="@color/blue_white"
        android:fontFamily="@font/font_three"
        android:textAlignment="center"
        android:layout_marginStart="40dp"
        android:textAllCaps="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/linImg"
        android:layout_marginEnd="30dp"/>
    <TextView
        android:id="@+id/dateTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/birthdayBtn"
        android:layout_marginTop="30dp"
        android:text="@string/date"
        android:textFontWeight="600"
        android:textSize="16sp"
        android:fontFamily="@font/font_five"
        android:textColor="@color/dark_brown"
       app:layout_constraintEnd_toStartOf="@id/linImg"
        app:layout_constraintStart_toStartOf="parent"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="@id/dateTitle"
        app:layout_constraintBottom_toBottomOf="@id/dateTitle"
        app:layout_constraintStart_toEndOf="@id/dateTitle"
        app:layout_constraintEnd_toStartOf="@id/birthdayBtn"
        android:background="@drawable/loading_back_re"
        android:paddingStart="15dp"
        android:backgroundTint="@color/light_gray"
        android:paddingEnd="15dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp">
        <TextView
            android:id="@+id/birthdayText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="May,12"
            android:textColor="@color/color_two"
            android:fontFamily="@font/font_three"
            android:textSize="18sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <DatePicker
        android:id="@+id/birthdayCalender"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:datePickerMode="spinner"
        android:calendarViewShown="false"
        android:spinnersShown="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/dateTitle"
        android:layout_marginTop="60dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>