<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_margin="10dp"
    android:id="@+id/cart_shopp_item_list"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    android:background="@drawable/border_explore_background_item"
    android:padding="5dp">
    <ImageView
        android:id="@+id/card_image_list"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/one"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_margin="10dp"/>
    <TextView
        android:id="@+id/card_name_item_list"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:fontFamily="@font/font_one"
        android:text="@string/item_name_explore"
        android:textColor="@color/dark_brown"
        android:textFontWeight="700"
        android:textSize="13sp"
        android:layout_marginStart="15dp"
        app:layout_constraintStart_toEndOf="@id/card_image_list"
        app:layout_constraintTop_toTopOf="@id/card_image_list"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/price_layout_card_list_item_basic"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="0dp"
        android:layout_marginTop="5dp"
        android:layout_marginEnd="5dp"
        app:layout_constraintStart_toStartOf="@id/card_name_item_list"
        app:layout_constraintTop_toBottomOf="@id/card_name_item_list">

        <ImageView
            android:id="@+id/icon_dollar_card_list_item"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/dollar"
            android:backgroundTint="@color/dark_brown"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/price_number_card_list_basic_item"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="0dp"
            android:fontFamily="@font/font_one"
            android:text="500"
            android:textColor="@color/dark_brown"
            android:textFontWeight="600"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/icon_dollar_card_list_item"
            app:layout_constraintStart_toEndOf="@id/icon_dollar_card_list_item"
            app:layout_constraintTop_toTopOf="@id/icon_dollar_card_list_item" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/price_layout_card_list_item_final"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginTop="5dp"
        android:layout_marginEnd="5dp"
        app:layout_constraintStart_toStartOf="@id/price_layout_card_list_item_basic"
        app:layout_constraintTop_toBottomOf="@id/price_layout_card_list_item_basic">

        <ImageView
            android:id="@+id/icon_dollar_card_list_item_final"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/dollar"
            android:backgroundTint="@color/dark_green"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/price_number_card_list_basic_item_final"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="0dp"
            android:fontFamily="@font/font_one"
            android:text="500"
            android:textColor="@color/dark_green"
            android:textFontWeight="600"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/icon_dollar_card_list_item_final"
            app:layout_constraintStart_toEndOf="@id/icon_dollar_card_list_item_final"
            app:layout_constraintTop_toTopOf="@id/icon_dollar_card_list_item_final" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <ImageView
        android:id="@+id/show_card_list_card_list"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_margin="2dp"
        android:background="@drawable/arrow_right"
        android:backgroundTint="@color/dark_brown"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <ImageView
        android:id="@+id/delete_card_list_explore"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:background="@drawable/trash"
        android:backgroundTint="@color/dark_brown"
        app:layout_constraintEnd_toStartOf="@id/show_card_list_card_list"
        app:layout_constraintTop_toTopOf="@id/show_card_list_card_list"
        app:layout_constraintBottom_toBottomOf="@id/show_card_list_card_list"
        android:layout_marginEnd="10dp"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="@id/show_card_list_card_list"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_margin="2dp"
        android:padding="1dp"
        android:background="@drawable/bg_menu_item_cart">

        <ImageView
            android:id="@+id/plus_card_list_explore"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/plus"
            android:backgroundTint="@color/dark_brown"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>
        <TextView
            android:id="@+id/number_card_list_basic_item"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/font_one"
            android:text="5"
            android:textColor="@color/dark_green"
            android:textFontWeight="600"
            android:textSize="15sp"
            android:layout_marginEnd="5dp"
            app:layout_constraintEnd_toStartOf="@id/plus_card_list_explore"
            app:layout_constraintTop_toTopOf="@id/plus_card_list_explore"
            app:layout_constraintBottom_toBottomOf="@id/plus_card_list_explore"/>
        <ImageView
            android:id="@+id/menus_card_list_explore"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:background="@drawable/menius"
            android:backgroundTint="@color/dark_brown"
            app:layout_constraintEnd_toStartOf="@id/number_card_list_basic_item"
            app:layout_constraintTop_toTopOf="@id/plus_card_list_explore"
            app:layout_constraintBottom_toBottomOf="@id/plus_card_list_explore"
            android:layout_marginEnd="5dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>