<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_popup"
    android:paddingBottom="30dp"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent">

    <ImageView
        android:id="@+id/linImg"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginTop="5dp"
        android:src="@drawable/line_progress"
        android:tint="@color/dark_brown"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="UseAppTint" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/total_mony_pay_layout"
        android:layout_width="wrap_content"
        android:layout_marginEnd="50dp"
        android:layout_marginTop="20dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        android:paddingRight="10dp"
        app:layout_constraintTop_toBottomOf="@id/linImg">

        <ImageView
            android:id="@+id/icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="10dp"
            android:src="@drawable/dollar"
            android:tint="@color/dark_brown"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/total_mony_pay"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="UseAppTint" />

        <TextView
            android:id="@+id/total_mony_pay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/font_welcome"
            android:justificationMode="inter_word"
            android:text="1200"
            android:textColor="@color/dark_brown"
            android:textFontWeight="800"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="@id/icon"
            app:layout_constraintStart_toEndOf="@id/icon"
            app:layout_constraintTop_toTopOf="@id/icon"
            tools:ignore="MissingConstraints" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/text_popup_methods"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="50dp"
        android:layout_marginTop="30dp"
        android:fontFamily="@font/font_five"
        android:justificationMode="inter_word"
        android:text="@string/method_text"
        android:textColor="@color/dark_brown"
        android:textFontWeight="800"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/total_mony_pay_layout" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/paypalBtn"
        android:layout_width="250dp"
        android:layout_height="50dp"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="5dp"
        android:background="@drawable/bg_btns"
        android:drawableStart="@drawable/paypal"
        android:drawablePadding="0dp"
        android:drawableTint="@color/blue_white"
        android:fontFamily="@font/font_one"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:text="PayPal"
        android:textAlignment="center"
        android:textAllCaps="false"
        android:textColor="@color/blue_white"
        android:textFontWeight="800"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/text_popup_methods"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/playPayBtn"
        android:layout_width="250dp"
        android:layout_height="50dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="5dp"
        android:background="@drawable/bg_btns"
        android:drawableStart="@drawable/google_pay"
        android:drawablePadding="0dp"
        android:drawableTint="@color/blue_white"
        android:fontFamily="@font/font_one"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:text="Google Pay"
        android:textAlignment="center"
        android:textAllCaps="false"
        android:textColor="@color/blue_white"
        android:textFontWeight="800"
        android:textSize="18sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/paypalBtn"
        app:layout_goneMarginBottom="30dp" />
</androidx.constraintlayout.widget.ConstraintLayout>