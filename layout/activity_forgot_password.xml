<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ForgotPasswordActivity"
    android:background="@color/lights_brown">
    <ImageView
        android:id="@+id/img_forgot_pass"
        android:layout_width="330dp"
        android:layout_height="330dp"
        android:background="@drawable/forgot_pass"
        android:layout_marginStart="-50dp"
        android:layout_marginBottom="-10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/text_reset_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="130dp"
        android:fontFamily="@font/font_five"
        android:text="@string/reset_pass"
        android:textAlignment="center"
        android:textAllCaps="false"
        android:textFontWeight="800"
        android:textSize="45sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <com.melikash98.editify.CustomInputEdit
        android:id="@+id/email_reset_pass"
        android:layout_width="300dp"
        android:singleLine="true"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:textFontWeight="800"
        app:activeBackground="@drawable/input_active"
        app:hintActiveColor="@color/brown"
        app:hintBackgroundColor="@color/lights_brown"
        app:hintColor="@color/gray"
        app:hintFamily="@font/font_three"
        app:hintIcon="@drawable/email"
        app:hintSize="16sp"
        app:hintText="@string/email"
        app:inactiveBackground="@drawable/input_inactive"
        app:inputColor="@color/black"
        app:inputFamily="@font/font_three"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_reset_title"
        app:textColor="@color/black"
        tools:ignore="MissingConstraints" />
    <com.example.loadinganimation.LoadingAnimation
        android:id="@+id/loadingAnim_rest"
        android:layout_width="300dp"
        android:layout_height="200dp"
        android:elevation="10dp"
        app:barType="@drawable/dot_anim"
        app:boldText="false"
        app:enlarge="5"
        app:textColor="@color/purple_500"
        app:textSize="15sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/email_reset_pass"
        app:layout_constraintBottom_toTopOf="@id/resetPassBtn"/>
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/resetPassBtn"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/email_reset_pass"
        android:layout_marginTop="70dp"
        android:text="@string/register"
        android:textSize="20sp"
        android:elevation="10dp"
        android:textColor="@color/blue_white"
        android:textAllCaps="false"
        android:fontFamily="@font/font_four"
        android:textFontWeight="800"
        android:background="@drawable/bg_btns"/>
</androidx.constraintlayout.widget.ConstraintLayout>