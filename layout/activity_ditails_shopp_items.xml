<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".DetailsShoppItemsActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/real_img_layout"
        android:layout_width="match_parent"
        android:layout_height="450dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/img_details_item"
            android:layout_width="match_parent"
            android:layout_height="430dp"
            android:scaleType="fitXY"
            android:src="@drawable/cake1_0"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.4"
            android:background="#000000" />

        <ImageView
            android:id="@+id/back_details_btn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="30dp"
            android:layout_marginTop="40dp"
            android:background="@drawable/back"
            android:backgroundTint="@color/color_one"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/like_details_item"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="30dp"
            android:background="@drawable/favorite"
            android:backgroundTint="@color/dark_red"
            app:layout_constraintBottom_toBottomOf="@id/back_details_btn"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/back_details_btn" />
    </androidx.constraintlayout.widget.ConstraintLayout>
    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/shimmer_img_layout"
        android:layout_width="match_parent"
        android:layout_height="450dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <View
            android:id="@+id/shimmer_img_def"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:backgroundTint="@color/gray"
            android:background="@drawable/loading_back_re"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </com.facebook.shimmer.ShimmerFrameLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/real_card_img_layout"
        android:layout_width="270dp"
        android:layout_height="70dp"
        android:layout_marginTop="160dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/card_images_details"
        android:padding="0dp"
        app:layout_constraintBottom_toTopOf="@id/cart_details_info_item"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:id="@+id/images_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="0dp"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.cardview.widget.CardView
                android:id="@+id/card_one"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:clipToPadding="false"
                app:cardBackgroundColor="@color/blue_white"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardPreventCornerOverlap="true"
                app:cardUseCompatPadding="false"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/image_one"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:src="@drawable/cake1_0" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/card_two"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginStart="5dp"
                android:clipToPadding="false"
                app:cardBackgroundColor="@color/blue_white"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardPreventCornerOverlap="true"
                app:cardUseCompatPadding="false"
                app:layout_constraintBottom_toBottomOf="@id/card_one"
                app:layout_constraintStart_toEndOf="@id/card_one"
                app:layout_constraintTop_toTopOf="@id/card_one"
                app:layout_goneMarginStart="10dp">

                <ImageView
                    android:id="@+id/image_two"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:src="@drawable/cake1_0" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/card_three"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginStart="5dp"
                android:clipToPadding="false"
                app:cardBackgroundColor="@color/blue_white"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardPreventCornerOverlap="true"
                app:cardUseCompatPadding="false"
                app:layout_constraintBottom_toBottomOf="@id/card_two"
                app:layout_constraintStart_toEndOf="@id/card_two"
                app:layout_constraintTop_toTopOf="@id/card_two"
                app:layout_goneMarginStart="10dp">

                <ImageView
                    android:id="@+id/image_three"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:src="@drawable/cake1_0" />
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/card_four"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginStart="5dp"
                android:clipToPadding="false"
                app:cardBackgroundColor="@color/blue_white"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardPreventCornerOverlap="true"
                app:cardUseCompatPadding="false"
                app:layout_constraintBottom_toBottomOf="@id/card_three"
                app:layout_constraintStart_toEndOf="@id/card_three"
                app:layout_constraintTop_toTopOf="@id/card_three"
                app:layout_goneMarginStart="10dp">

                <ImageView
                    android:id="@+id/image_four"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:src="@drawable/cake1_0" />
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/shimmer_card_img_layout"
        android:visibility="gone"
        android:layout_width="270dp"
        android:layout_height="70dp"
        android:layout_marginTop="160dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/card_images_details"
        android:padding="0dp"
        app:layout_constraintBottom_toTopOf="@id/cart_details_info_item"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false">

            <View
                android:id="@+id/shimmer_img_one"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_margin="5dp"
                android:backgroundTint="@color/gray"
                android:background="@drawable/loading_back_re"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:id="@+id/shimmer_img_two"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:backgroundTint="@color/gray"
                android:layout_margin="5dp"
                android:background="@drawable/loading_back_re"
                app:layout_constraintBottom_toBottomOf="@id/shimmer_img_one"
                app:layout_constraintStart_toEndOf="@id/shimmer_img_one"
                app:layout_constraintTop_toTopOf="@id/shimmer_img_one" />

            <View
                android:id="@+id/shimmer_img_three"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:backgroundTint="@color/gray"
                android:layout_margin="5dp"
                android:background="@drawable/loading_back_re"
                app:layout_constraintBottom_toBottomOf="@id/shimmer_img_one"
                app:layout_constraintStart_toEndOf="@id/shimmer_img_two"
                app:layout_constraintTop_toTopOf="@id/shimmer_img_one" />

            <View
                android:id="@+id/shimmer_img_four"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_margin="5dp"
                android:backgroundTint="@color/gray"
                android:background="@drawable/loading_back_re"
                app:layout_constraintBottom_toBottomOf="@id/shimmer_img_one"
                app:layout_constraintStart_toEndOf="@id/shimmer_img_three"
                app:layout_constraintTop_toTopOf="@id/shimmer_img_one" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.facebook.shimmer.ShimmerFrameLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cart_details_info_item"
        android:layout_width="match_parent"
        android:layout_height="500dp"
        android:background="@drawable/bg_card_details"
        android:padding="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/real_info_card_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout_two"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/name_detail_item"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:fontFamily="@font/font_sex"
                    android:text="@string/name_details"
                    android:textAlignment="center"
                    android:textColor="@color/dark_brown"
                    android:textSize="22sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/layout_one"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="30dp"
                    app:layout_constraintBottom_toBottomOf="@id/name_detail_item"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/name_detail_item">

                    <ImageView
                        android:id="@+id/icon_dollar_detail_item"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/dollar"
                        android:backgroundTint="@color/dark_brown"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/price_detail_item"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:fontFamily="@font/font_sex"
                        android:text="2200"
                        android:textAlignment="center"
                        android:textColor="@color/dark_brown"
                        android:textFontWeight="800"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@id/icon_dollar_detail_item"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <ScrollView
                android:id="@+id/scrollView"
                android:layout_width="match_parent"
                android:layout_height="900dp"
                android:layout_marginVertical="30dp"
                android:paddingBottom="250dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/layout_two">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="200dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="200dp"
                        android:id="@+id/layout">

                        <TextView
                            android:id="@+id/title_weight_detail_item"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="30dp"
                            android:layout_marginTop="10dp"
                            android:fontFamily="@font/font_one"
                            android:text="@string/select_weight"
                            android:textAlignment="center"
                            android:textColor="@color/gray"
                            android:textFontWeight="600"
                            android:textSize="16sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <LinearLayout
                            android:id="@+id/weight_layout_btn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:orientation="horizontal"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="@id/title_weight_detail_item"
                            app:layout_constraintTop_toBottomOf="@id/title_weight_detail_item">

                            <androidx.appcompat.widget.AppCompatButton
                                android:id="@+id/btn_weight_one"
                                android:layout_width="80dp"
                                android:layout_height="40dp"
                                android:background="@drawable/btn_details"
                                android:fontFamily="@font/font_five"
                                android:text="@string/weight_one"
                                android:textAlignment="center"
                                android:textAllCaps="false"
                                android:textColor="@color/blue_white"
                                android:textFontWeight="600"
                                android:textSize="18sp" />

                            <androidx.appcompat.widget.AppCompatButton
                                android:id="@+id/btn_weight_two"
                                android:layout_width="80dp"
                                android:layout_height="40dp"
                                android:layout_marginStart="5dp"
                                android:background="@drawable/btn_details"
                                android:fontFamily="@font/font_five"
                                android:text="@string/weight_two"
                                android:textAlignment="center"
                                android:textAllCaps="false"
                                android:textColor="@color/blue_white"
                                android:textFontWeight="600"
                                android:textSize="18sp" />

                            <androidx.appcompat.widget.AppCompatButton
                                android:id="@+id/btn_weight_three"
                                android:layout_width="80dp"
                                android:layout_height="40dp"
                                android:layout_marginStart="5dp"
                                android:background="@drawable/btn_details"
                                android:fontFamily="@font/font_five"
                                android:text="@string/weight_three"
                                android:textAlignment="center"
                                android:textAllCaps="false"
                                android:textColor="@color/blue_white"
                                android:textFontWeight="600"
                                android:textSize="18sp" />

                            <androidx.appcompat.widget.AppCompatButton
                                android:id="@+id/btn_weight_four"
                                android:layout_width="80dp"
                                android:layout_height="40dp"
                                android:layout_marginStart="5dp"
                                android:background="@drawable/btn_details"
                                android:fontFamily="@font/font_five"
                                android:text="@string/weight_four"
                                android:textAlignment="center"
                                android:textAllCaps="false"
                                android:textColor="@color/blue_white"
                                android:textFontWeight="600"
                                android:textSize="18sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/title_additional_detail_item"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="30dp"
                            android:layout_marginTop="20dp"
                            android:fontFamily="@font/font_one"
                            android:text="@string/additional_items"
                            android:textAlignment="center"
                            android:textColor="@color/gray"
                            android:textFontWeight="600"
                            android:textSize="16sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/weight_layout_btn"
                            tools:ignore="MissingConstraints" />

                        <LinearLayout
                            android:id="@+id/additional_layout"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="-20dp"
                            android:layout_marginTop="20dp"
                            android:orientation="horizontal"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="@id/title_weight_detail_item"
                            app:layout_constraintTop_toBottomOf="@id/title_additional_detail_item">

                            <androidx.appcompat.widget.AppCompatButton
                                android:id="@+id/btn_additional_one"
                                android:layout_width="120dp"
                                android:layout_height="40dp"
                                android:background="@drawable/btn_details"
                                android:fontFamily="@font/font_five"
                                android:text="@string/additional_one"
                                android:textAlignment="center"
                                android:textAllCaps="false"
                                android:textColor="@color/blue_white"
                                android:textFontWeight="600"
                                android:textSize="14sp" />

                            <androidx.appcompat.widget.AppCompatButton
                                android:id="@+id/btn_additional_two"
                                android:layout_width="120dp"
                                android:layout_height="40dp"
                                android:layout_marginStart="5dp"
                                android:background="@drawable/btn_details"
                                android:fontFamily="@font/font_five"
                                android:text="@string/additional_two"
                                android:textAlignment="center"
                                android:textAllCaps="false"
                                android:textColor="@color/blue_white"
                                android:textFontWeight="600"
                                android:textSize="14sp" />

                            <androidx.appcompat.widget.AppCompatButton
                                android:id="@+id/btn_additional_three"
                                android:layout_width="120dp"
                                android:layout_height="40dp"
                                android:layout_marginStart="5dp"
                                android:background="@drawable/btn_details"
                                android:fontFamily="@font/font_five"
                                android:text="@string/additional_three"
                                android:textAlignment="center"
                                android:textAllCaps="false"
                                android:textColor="@color/blue_white"
                                android:textFontWeight="600"
                                android:textSize="14sp" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/title_description_detail_item"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="20dp"
                            android:layout_marginTop="20dp"
                            android:fontFamily="@font/font_one"
                            android:text="Description"
                            android:textAlignment="center"
                            android:textColor="@color/gray"
                            android:textFontWeight="600"
                            android:textSize="16sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/additional_layout" />

                        <TextView
                            android:id="@+id/description_detail_item"
                            android:layout_width="350dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="20dp"
                            android:layout_marginTop="30dp"
                            android:fontFamily="@font/font_three"
                            android:justificationMode="inter_word"
                            android:text="@string/details_description"
                            android:textColor="@color/gray"
                            android:textFontWeight="400"
                            android:textSize="13sp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@id/title_description_detail_item" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </ScrollView>
        </androidx.constraintlayout.widget.ConstraintLayout>


        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/add_to_card_btn"
            android:layout_width="250dp"
            android:layout_height="50dp"
            android:layout_marginBottom="25dp"
            android:background="@drawable/bg_btns"
            android:drawableStart="@drawable/add_card"
            android:drawablePadding="0dp"
            android:drawableTint="@color/blue_white"
            android:fontFamily="@font/font_one"
            android:paddingStart="40dp"
            android:paddingEnd="40dp"
            android:text="@string/add_to_cart"
            android:textAlignment="center"
            android:textAllCaps="false"
            android:textColor="@color/blue_white"
            android:textFontWeight="800"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmer_info_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipChildren="false"
                android:clipToPadding="false">
                <View
                    android:id="@+id/shimmer_name"
                    android:layout_width="150dp"
                    android:layout_height="30dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginStart="10dp"
                    android:backgroundTint="@color/gray"
                    android:background="@drawable/loading_back_re"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <View
                    android:id="@+id/shimmer_price"
                    android:layout_width="100dp"
                    android:layout_height="30dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginEnd="10dp"
                    android:backgroundTint="@color/gray"
                    android:background="@drawable/loading_back_re"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
                <View
                    android:id="@+id/shimmer_weight"
                    android:layout_width="120dp"
                    android:layout_height="30dp"
                    android:layout_marginTop="30dp"
                    android:layout_marginStart="25dp"
                    android:backgroundTint="@color/gray"
                    android:background="@drawable/loading_back_re"
                    app:layout_constraintTop_toBottomOf="@id/shimmer_name"
                    app:layout_constraintStart_toStartOf="parent"/>
                <LinearLayout
                    android:id="@+id/shimmer_num_weight"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginStart="40dp"
                    android:layout_marginEnd="40dp"
                    app:layout_constraintTop_toBottomOf="@id/shimmer_weight"
                    android:layout_marginTop="13dp">
                    <View
                        android:id="@+id/shimmer_weight_one"
                        android:layout_width="70dp"
                        android:layout_height="40dp"
                        android:backgroundTint="@color/gray"
                        android:background="@drawable/loading_back_re"/>
                    <View
                        android:id="@+id/shimmer_weight_two"
                        android:layout_width="70dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="5dp"
                        android:backgroundTint="@color/gray"
                        android:background="@drawable/loading_back_re"/>
                    <View
                        android:id="@+id/shimmer_weight_three"
                        android:layout_width="70dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="5dp"
                        android:backgroundTint="@color/gray"
                        android:background="@drawable/loading_back_re"/>
                    <View
                        android:id="@+id/shimmer_weight_four"
                        android:layout_width="70dp"
