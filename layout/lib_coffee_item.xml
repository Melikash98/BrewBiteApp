<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_margin="10dp"
    android:clipChildren="false"
    android:clipToPadding="false"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/real_coffee_lib_card"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/lib_image_coffee"
            android:layout_width="65dp"
            android:layout_height="65dp"
            android:src="@drawable/one"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:elevation="10dp"/>
        <ImageView
            android:id="@+id/favorite_coffee_lib"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:background="@drawable/favorite"
            android:backgroundTint="@color/dark_brown"
            android:layout_marginEnd="-3dp"
            android:layout_marginTop="-3dp"
            app:layout_constraintEnd_toEndOf="@id/lib_image_coffee"
            app:layout_constraintTop_toTopOf="@id/lib_image_coffee"
            android:elevation="20dp"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="25dp"
            android:background="@drawable/border_explore_background_item"
            android:padding="3dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <ImageView
                android:id="@+id/add_lib_coffee_btn"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/add_item"
                android:backgroundTint="@color/dark_brown"
                android:layout_margin="5dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <ImageView
                android:id="@+id/show_lib_coffee_btn"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/arrow_right"
                android:backgroundTint="@color/dark_brown"
                android:layout_marginBottom="5dp"
               app:layout_constraintEnd_toEndOf="@id/add_lib_coffee_btn"
                app:layout_constraintStart_toStartOf="@id/add_lib_coffee_btn"
                app:layout_constraintBottom_toBottomOf="parent"/>
            <TextView
                android:id="@+id/lib_name_item_coffee"
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginStart="60dp"
                android:text="@string/item_name_explore"
                android:textColor="@color/dark_brown"
                android:fontFamily="@font/font_name"
                android:textFontWeight="600"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="@id/lib_name_item_coffee"
                app:layout_constraintTop_toTopOf="@id/lib_name_item_coffee"
                app:layout_constraintStart_toEndOf="@id/lib_name_item_coffee"
                android:layout_marginStart="15dp">

                <ImageView
                    android:id="@+id/star_percent_lib_icon"
                    android:layout_width="15dp"
                    android:layout_height="15dp"
                    android:background="@drawable/star"
                    android:backgroundTint="@color/gold" />
                <TextView
                    android:id="@+id/lib_percent_number_coffee_item"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3.5"
                    android:fontFamily="@font/font_name"
                    android:textColor="@color/dark_brown"
                    android:layout_marginStart="5dp"
                    app:layout_constraintTop_toTopOf="@id/star_percent_lib_icon"
                    app:layout_constraintBottom_toBottomOf="@id/star_percent_lib_icon"
                    app:layout_constraintStart_toEndOf="@id/star_percent_lib_icon"
                    android:textFontWeight="900"
                    android:textSize="12sp"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <TextView
                android:id="@+id/lib_des_item_coffee"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:justificationMode="inter_word"
                android:fontFamily="@font/font_three"
                android:text="@string/item_description_min_lib"
                android:textColor="@color/gray"
                android:textFontWeight="700"
                android:textSize="11sp"
                android:layout_marginEnd="30dp"
                android:layout_marginStart="10dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@id/lib_name_item_coffee"
                app:layout_constraintTop_toBottomOf="@id/lib_name_item_coffee"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/price_layout_lib_coffee_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:layout_marginEnd="5dp"
                app:layout_constraintTop_toBottomOf="@id/lib_des_item_coffee"
                app:layout_constraintStart_toStartOf="@id/lib_name_item_coffee">

                <ImageView
                    android:id="@+id/icon_dollar_explore_coffee_item"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:background="@drawable/dollar"
                    android:backgroundTint="@color/dark_brown"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/price_number_explore_coffee_item"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="0dp"
                    android:text="500"
                    android:textColor="@color/dark_brown"
                    android:fontFamily="@font/font_name"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="@id/icon_dollar_explore_coffee_item"
                    app:layout_constraintStart_toEndOf="@id/icon_dollar_explore_coffee_item"
                    app:layout_constraintTop_toTopOf="@id/icon_dollar_explore_coffee_item" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/shimmer_coffee_lib_card"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false">

            <View
                android:id="@+id/shimmer_image_lib_coffee"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:background="@drawable/loading_back_circle"
                android:elevation="10dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="350dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="25dp"
                android:background="@drawable/border_explore_background_item"
                android:padding="3dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <View
                    android:id="@+id/shimmer_name_lib_coffee"
                    android:layout_width="90dp"
                    android:layout_height="25dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginStart="60dp"
                    android:background="@drawable/loading_back_re"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/shimmer_stars_lib_coffee"
                    android:layout_width="60dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="-10dp"
                    android:background="@drawable/loading_back_re"
                    app:layout_constraintStart_toEndOf="@id/shimmer_name_lib_coffee"
                    app:layout_constraintTop_toTopOf="@id/shimmer_name_lib_coffee"
                    app:layout_constraintBottom_toBottomOf="@id/shimmer_name_lib_coffee"
                    android:layout_marginStart="10dp"/>
                <View
                    android:id="@+id/shimmer_percent_lib_coffee"
                    android:layout_width="200dp"
                    android:layout_height="25dp"
                    android:layout_marginTop="5dp"
                    android:background="@drawable/loading_back_re"
                    app:layout_constraintTop_toBottomOf="@id/shimmer_name_lib_coffee"
                    app:layout_constraintStart_toStartOf="@id/shimmer_name_lib_coffee"
                    android:layout_marginStart="30dp"/>

                <View

                    android:id="@+id/shimmer_price_lib_coffee"
                    android:layout_width="50dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginStart="1dp"
                    android:layout_marginBottom="6dp"
                    android:background="@drawable/loading_back_re"
                  app:layout_constraintTop_toBottomOf="@id/shimmer_percent_lib_coffee"
                    app:layout_constraintStart_toStartOf="@id/shimmer_name_lib_coffee"/>
                <View
                    android:id="@+id/shimmer_add_lib_coffee"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:background="@drawable/loading_back_re"
                   app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="@id/shimmer_show_lib_coffee"
                    app:layout_constraintStart_toStartOf="@id/shimmer_show_lib_coffee"/>
                <View
                    android:id="@+id/shimmer_show_lib_coffee"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_marginEnd="20dp"
                    android:background="@drawable/loading_back_re"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:layout_marginTop="5dp"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.facebook.shimmer.ShimmerFrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>