<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    android:background="@drawable/border_explore_background_item"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:padding="0dp"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/real_all_lib_card"
        android:layout_width="380dp"
        android:layout_height="wrap_content"
        android:padding="0dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_img_lib"
            android:layout_width="130dp"
            android:layout_height="100dp"
            android:layout_margin="10dp"
            android:padding="0dp"
            app:cardBackgroundColor="@color/blue_white"
            app:cardCornerRadius="5dp"
            app:cardElevation="0dp"
            app:cardPreventCornerOverlap="false"
            app:cardUseCompatPadding="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/img_all_items_lib"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:cropToPadding="true"
                android:scaleType="centerCrop"
                android:src="@drawable/cake1_0" />

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.5"
                android:src="#000000" />

        </com.google.android.material.card.MaterialCardView>

        <ImageView
            android:id="@+id/favorite_all_lib"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/favorite"
            android:backgroundTint="@color/blue_white"
            android:elevation="30dp"
            app:layout_constraintEnd_toEndOf="@id/card_img_lib"
            app:layout_constraintTop_toTopOf="@id/card_img_lib" />

        <TextView
            android:id="@+id/lib_name_item_all"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/font_name"
            android:text="@string/item_name_explore"
            android:textColor="@color/dark_brown"
            android:textFontWeight="600"
            android:textSize="14sp"
            app:layout_constraintStart_toEndOf="@id/card_img_lib"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/lib_des_item_all"
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="30dp"
            android:fontFamily="@font/font_three"
            android:justificationMode="inter_word"
            android:text="@string/item_description_min_lib"
            android:textColor="@color/gray"
            android:textFontWeight="700"
            android:textSize="10sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/lib_name_item_all"
            app:layout_constraintTop_toBottomOf="@id/lib_name_item_all" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/score_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            app:layout_constraintBottom_toBottomOf="@id/favorite_all_lib"
            app:layout_constraintStart_toStartOf="@id/card_img_lib"
            app:layout_constraintTop_toTopOf="@id/favorite_all_lib">

            <ImageView
                android:id="@+id/star_percent_lib_icon_all"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:background="@drawable/star"
                android:backgroundTint="@color/gold" />

            <TextView
                android:id="@+id/lib_percent_number_all_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:fontFamily="@font/font_one"
                android:text="3.5"
                android:textColor="@color/blue_white"
                android:textFontWeight="900"
                android:textSize="13sp"
                app:layout_constraintBottom_toBottomOf="@id/star_percent_lib_icon_all"
                app:layout_constraintStart_toEndOf="@id/star_percent_lib_icon_all"
                app:layout_constraintTop_toTopOf="@id/star_percent_lib_icon_all" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/price_layout_lib_all_item"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="5dp"
            app:layout_constraintStart_toStartOf="@id/lib_name_item_all"
            app:layout_constraintTop_toBottomOf="@id/lib_des_item_all">

            <ImageView
                android:id="@+id/icon_dollar_explore_coffee_item"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:background="@drawable/dollar"
                android:backgroundTint="@color/dark_brown"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/price_number_lib_all_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="0dp"
                android:fontFamily="@font/font_name"
                android:text="500"
                android:textColor="@color/dark_brown"
                android:textFontWeight="600"
                android:textSize="16sp"
                app:layout_constraintBottom_toBottomOf="@id/icon_dollar_explore_coffee_item"
                app:layout_constraintStart_toEndOf="@id/icon_dollar_explore_coffee_item"
                app:layout_constraintTop_toTopOf="@id/icon_dollar_explore_coffee_item" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <ImageView
            android:id="@+id/add_lib_all_btn"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="25dp"
            android:background="@drawable/add_item"
            android:backgroundTint="@color/dark_brown"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/show_lib_all_btn"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/arrow_right"
            android:backgroundTint="@color/dark_brown"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@id/add_lib_all_btn"
            app:layout_constraintStart_toStartOf="@id/add_lib_all_btn" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/shimmer_all_lib_card"
        android:layout_width="380dp"
        android:layout_height="120dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/border_explore_background_item"
            android:padding="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:id="@+id/shimmer_img_all_lib"
                android:layout_width="140dp"
                android:layout_height="100dp"
                android:layout_margin="10dp"
                android:padding="0dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />


            <View
                android:id="@+id/shimmer_name_all_lib"
                android:layout_width="100dp"
                android:layout_height="25dp"
                android:layout_marginStart="15dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/loading_back_re"
                app:layout_constraintStart_toEndOf="@id/shimmer_img_all_lib"
                app:layout_constraintTop_toTopOf="@id/shimmer_img_all_lib" />

            <View
                android:id="@+id/shimmer_des_all_lib"
                android:layout_width="170dp"
                android:layout_height="30dp"
                android:layout_marginStart="10dp"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="11dp"
                android:background="@drawable/loading_back_re"
                app:layout_constraintStart_toStartOf="@id/shimmer_name_all_lib"
                app:layout_constraintTop_toBottomOf="@id/shimmer_name_all_lib" />

            <View
                android:id="@+id/shimmer_price_all_lib"
                android:layout_width="50dp"
                android:layout_height="17dp"
                android:layout_marginStart="5dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/loading_back_re"
                app:layout_constraintStart_toStartOf="@id/shimmer_name_all_lib"
                app:layout_constraintTop_toBottomOf="@id/shimmer_des_all_lib" />

            <View
                android:id="@+id/shimmer_add_all_lib"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginTop="3dp"
                android:layout_marginEnd="12dp"
                android:background="@drawable/loading_back_re"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:id="@+id/shimmer_show_all_lib"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginEnd="1dp"
                android:layout_marginBottom="3dp"
                android:background="@drawable/loading_back_re"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="@id/shimmer_add_all_lib"
                app:layout_constraintStart_toStartOf="@id/shimmer_add_all_lib" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.facebook.shimmer.ShimmerFrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>