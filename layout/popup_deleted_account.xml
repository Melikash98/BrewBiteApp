<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="30dp"
    android:id="@+id/your_root_layout"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    android:background="@drawable/bg_dialog_popup_two">
    <ImageView
        android:id="@+id/linImgPopup"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/line_progress"
        android:tint="@color/dark_brown"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="5dp"
        tools:ignore="UseAppTint" />
    <TextView
        android:id="@+id/text_popup_deleted"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/linImgPopup"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="50dp"
        android:text="@string/deleted_message"
        android:textColor="@color/dark_brown"
        android:textSize="14sp"
        android:textFontWeight="800"
        android:justificationMode="inter_word"
        android:fontFamily="@font/font_five"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/ysePopup"
        android:layout_width="wrap_content"
        app:layout_goneMarginBottom="30dp"
        android:layout_height="50dp"
        app:layout_constraintStart_toStartOf="@id/text_popup_deleted"
        app:layout_constraintTop_toBottomOf="@id/text_popup_deleted"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="5dp"
        android:drawablePadding="0dp"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:drawableTint="@color/blue_white"
        android:background="@drawable/bg_btns"
        android:text="@string/yes"
        android:textAllCaps="false"
        android:textAlignment="center"
        android:textSize="18sp"
        android:textFontWeight="800"
        android:textColor="@color/blue_white"
        android:fontFamily="@font/font_one"/>
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/noPopup"
        android:layout_width="wrap_content"
      app:layout_constraintTop_toTopOf="@id/ysePopup"
        app:layout_constraintBottom_toBottomOf="@id/ysePopup"
        android:layout_height="50dp"
        app:layout_constraintStart_toEndOf="@id/ysePopup"
        app:layout_constraintEnd_toEndOf="@id/text_popup_deleted"
        app:layout_constraintTop_toBottomOf="@id/text_popup_deleted"
        android:drawablePadding="0dp"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:drawableTint="@color/dark_brown"
        android:background="@drawable/bg_btns"
        android:text="@string/no"
        android:backgroundTint="@color/gray"
        android:textAllCaps="false"
        android:textAlignment="center"
        android:textSize="18sp"
        android:textFontWeight="800"
        android:textColor="@color/blue_white"
        android:fontFamily="@font/font_one"/>

    <com.example.loadinganimation.LoadingAnimation
        android:id="@+id/loadingAnim_popupDeleted"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:elevation="10dp"
        app:barType="@drawable/bouncy_balls"
        app:boldText="false"
        app:enlarge="5"
        app:textColor="@color/purple_500"
        app:textSize="15sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ysePopup"
        android:layout_marginTop="20dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>