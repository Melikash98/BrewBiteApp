<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="30dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    android:background="@drawable/bg_dialog_popup">
    <ImageView
        android:id="@+id/linImg"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@drawable/line_progress"
        android:tint="@color/dark_brown"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="5dp"/>
    <TextView
        android:id="@+id/text_popup"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/linImg"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="50dp"
        android:text="@string/popup_add_cart_text"
        android:textColor="@color/dark_brown"
        android:textSize="14sp"
        android:textFontWeight="800"
        android:justificationMode="inter_word"
        android:fontFamily="@font/font_five"/>
    <com.melikash98.editify.CustomInputEdit
        android:id="@+id/message_option"
        android:layout_width="350dp"
        android:layout_height="wrap_content"
        android:minHeight="50dp"
        app:inputMaxLines="5"
        app:inputMinLines="1"
        app:inputSingleLine="false"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="40dp"
        android:textFontWeight="800"
        app:activeBackground="@drawable/input_active_search"
        app:hintActiveColor="@color/dark_brown"
        app:hintBackgroundColor="@color/blue_white"
        app:hintColor="@color/dark_brown"
        app:hintFamily="@font/font_three"
        app:hintIcon="@drawable/note_icon"
        app:hintSize="16sp"
        app:hintText="Notes"
        app:inactiveBackground="@drawable/input_inactive_search_two"
        app:inputColor="@color/dark_brown"
        app:inputFamily="@font/font_three"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_popup"
        app:layout_constraintStart_toStartOf="parent"
        app:textColor="@color/dark_brown"
        tools:ignore="MissingConstraints" />
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/add_to_card_btn"
        android:layout_width="250dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_goneMarginBottom="30dp"
        android:layout_height="50dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/message_option"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="5dp"
        android:drawableStart="@drawable/add_card"
        android:drawablePadding="0dp"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:drawableTint="@color/blue_white"
        android:background="@drawable/bg_btns"
        android:text="@string/add_to_cart"
        android:textAllCaps="false"
        android:textAlignment="center"
        android:textSize="18sp"
        android:textFontWeight="800"
        android:textColor="@color/blue_white"
        android:fontFamily="@font/font_one"/>
</androidx.constraintlayout.widget.ConstraintLayout>