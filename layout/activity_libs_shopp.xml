<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".LibsShoppActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/back_lib_btn"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginStart="30dp"
        android:background="@drawable/loading_back_re"
        android:backgroundTint="@color/lights_brown"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title_layout">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/back"
            android:backgroundTint="@color/dark_brown"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.melikash98.editify.CustomInputEdit
        android:id="@+id/search_lib"
        android:layout_width="350dp"
        android:layout_height="80dp"
        android:layout_marginTop="50dp"
        android:layout_marginBottom="40dp"
        android:singleLine="true"
        android:textFontWeight="800"
        app:activeBackground="@drawable/input_active_search"
        app:hintActiveColor="@color/dark_brown"
        app:hintBackgroundColor="@color/white"
        app:hintColor="@color/dark_brown"
        app:hintFamily="@font/font_three"
        app:hintIcon="@drawable/search"
        app:hintSize="16sp"
        app:hintText="@string/search"
        app:inactiveBackground="@drawable/input_inactive_search_two"
        app:inputColor="@color/dark_brown"
        app:inputFamily="@font/font_three"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/back_lib_btn"
        app:textColor="@color/dark_brown"
        tools:ignore="MissingConstraints" />


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/title_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/icon_cat_lib_item"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:scaleType="fitCenter"
            android:src="@drawable/cookie"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/name_cat_lib_item"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:fontFamily="@font/font_three"
            android:text="@string/name_cats"
            android:textColor="@color/dark_brown"
            android:textFontWeight="900"
            android:textSize="20sp"
            app:layout_constraintBottom_toBottomOf="@id/icon_cat_lib_item"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/icon_cat_lib_item"
            app:layout_constraintTop_toTopOf="@id/icon_cat_lib_item" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/libRec"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="10dp"
        app:layout_constraintTop_toBottomOf="@id/search_lib" />

</androidx.constraintlayout.widget.ConstraintLayout>