<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    android:clipChildren="false"
    android:clipToPadding="false"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:visibility="visible"
        android:id="@+id/real_coffee_card"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/explore_image_coffee"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:src="@drawable/one"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:elevation="10dp"/>
        <ImageView
            android:id="@+id/favorite_coffee_explore"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:background="@drawable/favorite"
            android:backgroundTint="@color/dark_brown"
            android:layout_marginStart="1dp"
            android:layout_marginBottom="2dp"
            app:layout_constraintStart_toStartOf="@id/explore_image_coffee"
            app:layout_constraintBottom_toBottomOf="@id/explore_image_coffee"
            android:elevation="20dp"/>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="130dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:background="@drawable/border_explore_background_item"
            android:padding="2dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/add_card_list_explore"
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:layout_margin="2dp"
                android:background="@drawable/add_card"
                android:backgroundTint="@color/dark_brown"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/explore_name_item_coffee"
                android:layout_width="110dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="35dp"
                android:textAlignment="center"
                android:fontFamily="@font/font_name"
                android:text="@string/item_name_explore"
                android:textColor="@color/dark_brown"
                android:textFontWeight="600"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:id="@+id/star_explore_coffee_items"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/explore_name_item_coffee">

                <ImageView
                    android:id="@+id/star_one"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/star"
                    android:backgroundTint="@color/gold"
                    android:tint="@color/gold" />

                <ImageView
                    android:id="@+id/star_two"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginStart="1dp"
                    android:background="@drawable/star"
                    android:backgroundTint="@color/gold"
                    android:tint="@color/gold" />

                <ImageView
                    android:id="@+id/star_three"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginStart="1dp"
                    android:background="@drawable/star"
                    android:backgroundTint="@color/gold"
                    android:tint="@color/gold" />

                <ImageView
                    android:id="@+id/star_four"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginStart="1dp"
                    android:background="@drawable/star"
                    android:backgroundTint="@color/gold"
                    android:tint="@color/gold" />

                <ImageView
                    android:id="@+id/star_five"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_marginStart="1dp"
                    android:background="@drawable/star"
                    android:backgroundTint="@color/gold"
                    android:tint="@color/gold" />
            </LinearLayout>

            <TextView
                android:id="@+id/explore_percentage_number_coffee"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/font_two"
                android:text="@string/percentage_coffee_item_explore"
                android:textColor="@color/gold"
                android:textFontWeight="600"
                android:textSize="10sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/star_explore_coffee_items" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/price_layout_explore_coffee_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="5dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/explore_percentage_number_coffee">

                <ImageView
                    android:id="@+id/icon_dollar_explore_coffee_item"
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:background="@drawable/dollar"
                    android:backgroundTint="@color/dark_brown"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/price_number_explore_coffee_item"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="0dp"
                    android:fontFamily="@font/font_name"
                    android:text="500"
                    android:textColor="@color/dark_brown"
                    android:textFontWeight="600"
                    android:textSize="12sp"
                    app:layout_constraintBottom_toBottomOf="@id/icon_dollar_explore_coffee_item"
                    app:layout_constraintStart_toEndOf="@id/icon_dollar_explore_coffee_item"
                    app:layout_constraintTop_toTopOf="@id/icon_dollar_explore_coffee_item" />
            </androidx.constraintlayout.widget.ConstraintLayout>
            <ImageView
                android:id="@+id/show_explore_coffee_item_btn"
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:background="@drawable/arrow_right"
                android:backgroundTint="@color/dark_brown"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="@id/price_layout_explore_coffee_item"
                app:layout_constraintTop_toTopOf="@id/price_layout_explore_coffee_item" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/shimmer_coffee_card"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false">

            <View
                android:id="@+id/shimmer_image_coffee"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:background="@drawable/loading_back_circle"
                android:elevation="10dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:background="@drawable/border_explore_background_item"
                android:padding="6dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <View
                    android:id="@+id/shimmer_name_coffee"
                    android:layout_width="80dp"
                    android:layout_height="15dp"
                    android:layout_marginTop="34dp"
                    android:background="@drawable/loading_back_re"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/shimmer_stars_coffee"
                    android:layout_width="50dp"
                    android:layout_height="10dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/loading_back_re"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/shimmer_name_coffee" />
                <View
                    android:id="@+id/shimmer_percent_coffee"
                    android:layout_width="30dp"
                    android:layout_height="10dp"
                    android:layout_marginTop="5dp"
                    android:background="@drawable/loading_back_re"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/shimmer_stars_coffee" />

                <View
                    android:id="@+id/shimmer_price_coffee"
                    android:layout_width="50dp"
                    android:layout_height="15dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginStart="1dp"
                    android:layout_marginBottom="6dp"
                    android:background="@drawable/loading_back_re"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/shimmer_percent_coffee" />
                <View
                    android:id="@+id/shimmer_add_coffee"
                    android:layout_width="17dp"
                    android:layout_height="17dp"
                    android:layout_marginTop="-3dp"
                    android:layout_marginEnd="-3dp"
                    android:layout_marginBottom="6dp"
                    android:background="@drawable/loading_back_re"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>
                <View
                    android:id="@+id/shimmer_show_coffee"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="0dp"
                    android:background="@drawable/loading_back_re"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/shimmer_price_coffee"
                    app:layout_constraintBottom_toBottomOf="@id/shimmer_price_coffee"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.facebook.shimmer.ShimmerFrameLayout>




</androidx.constraintlayout.widget.ConstraintLayout>