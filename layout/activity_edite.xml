<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".EditeActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/back_edit_btn"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="70dp"
        android:background="@drawable/loading_back_re"
        android:backgroundTint="@color/lights_brown"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/back"
            android:backgroundTint="@color/dark_brown"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="150dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.melikash98.editify.CustomInputEdit
            android:id="@+id/name_edit"
            android:layout_width="350dp"
            android:singleLine="true"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"
            android:minHeight="50dp"
            android:textFontWeight="800"
            app:activeBackground="@drawable/input_active_search"
            app:hintActiveColor="@color/dark_brown"
            app:hintBackgroundColor="@color/white"
            app:hintColor="@color/dark_brown"
            app:hintFamily="@font/font_three"
            app:hintIcon="@drawable/profile_icon"
            app:hintSize="16sp"
            app:hintText="@string/full_name"
            app:inactiveBackground="@drawable/input_inactive_search_two"
            app:inputColor="@color/dark_brown"
            app:inputFamily="@font/font_three"
            app:inputSingleLine="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:textColor="@color/dark_brown"
            tools:ignore="MissingConstraints" />

        <com.melikash98.editify.CustomInputEdit
            android:id="@+id/userName_edit"
            android:layout_width="350dp"
            android:singleLine="true"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="40dp"
            android:minHeight="50dp"
            android:textFontWeight="800"
            app:activeBackground="@drawable/input_active_search"
            app:hintActiveColor="@color/dark_brown"
            app:hintBackgroundColor="@color/white"
            app:hintColor="@color/dark_brown"
            app:hintFamily="@font/font_three"
            app:hintIcon="@drawable/user_name_icon"
            app:hintSize="16sp"
            app:hintText="@string/user_name"
            app:inactiveBackground="@drawable/input_inactive_search_two"
            app:inputColor="@color/dark_brown"
            app:inputFamily="@font/font_three"
            app:inputSingleLine="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/name_edit"
            app:textColor="@color/dark_brown"
            tools:ignore="MissingConstraints" />

        <com.melikash98.editify.CustomInputEdit
            android:id="@+id/gender_edit"
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="40dp"
            app:dropdownMode="true"
            app:dropdownItemTextColor="@color/dark_brown"
            app:dropdownBackground="@color/white"
            app:dropdownItemFamily="@font/font_three"
            android:minHeight="50dp"
            android:textFontWeight="800"
            app:dropdownArrowIcon="@drawable/arrow_down_icon"
            app:activeBackground="@drawable/input_active_search"
            app:hintActiveColor="@color/dark_brown"
            app:hintBackgroundColor="@color/white"
            app:hintColor="@color/dark_brown"
            app:hintFamily="@font/font_three"
            app:hintIcon="@drawable/gender_icon"
            app:hintSize="16sp"
            app:hintText="@string/gender"
            app:inactiveBackground="@drawable/input_inactive_search_two"
            app:inputColor="@color/dark_brown"
            app:inputFamily="@font/font_three"
            app:inputSingleLine="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/userName_edit"
            app:textColor="@color/dark_brown"
            tools:ignore="MissingConstraints" />

        <com.melikash98.editify.CustomInputEdit
            android:id="@+id/location_edit"
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="40dp"
            app:buttonMode="true"
            android:minHeight="50dp"
            android:textFontWeight="800"
            app:activeBackground="@drawable/input_active_search"
            app:hintActiveColor="@color/dark_brown"
            app:hintBackgroundColor="@color/white"
            app:hintColor="@color/dark_brown"
            app:hintFamily="@font/font_three"
            app:hintIcon="@drawable/location_icon"
            app:hintSize="16sp"
            app:hintText="@string/location"
            app:inactiveBackground="@drawable/input_inactive_search_two"
            app:inputColor="@color/dark_brown"
            app:inputFamily="@font/font_three"
            app:inputSingleLine="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/gender_edit"
            app:textColor="@color/dark_brown"
            tools:ignore="MissingConstraints" />

        <com.melikash98.editify.CustomInputEdit
            android:id="@+id/phone_edit"
            android:layout_width="350dp"
            android:singleLine="true"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="40dp"
            android:minHeight="50dp"
            android:textFontWeight="800"
            app:activeBackground="@drawable/input_active_search"
            app:hintActiveColor="@color/dark_brown"
            app:hintBackgroundColor="@color/white"
            app:hintColor="@color/dark_brown"
            app:hintFamily="@font/font_three"
            app:hintIcon="@drawable/phone_icon"
            app:hintSize="16sp"
            app:hintText="@string/phone_number"
            app:inactiveBackground="@drawable/input_inactive_search_two"
            app:inputColor="@color/dark_brown"
            app:inputFamily="@font/font_three"
            app:inputSingleLine="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/location_edit"
            app:textColor="@color/dark_brown"
            tools:ignore="MissingConstraints" />

        <com.melikash98.editify.CustomInputEdit
            android:id="@+id/birthday_edit"
            android:layout_width="350dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="40dp"
            android:minHeight="50dp"
            app:buttonMode="true"
            android:textFontWeight="800"
            app:activeBackground="@drawable/input_active_search"
            app:hintActiveColor="@color/dark_brown"
            app:hintBackgroundColor="@color/white"
            app:hintColor="@color/dark_brown"
            app:hintFamily="@font/font_three"
            app:hintIcon="@drawable/birthday_icon"
            app:hintSize="16sp"
            app:hintText="@string/birthday"
            app:inactiveBackground="@drawable/input_inactive_search_two"
            app:inputColor="@color/dark_brown"
            app:inputFamily="@font/font_three"
            app:inputSingleLine="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/phone_edit"
            app:textColor="@color/dark_brown"
            tools:ignore="MissingConstraints" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/registerBtn"
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="70dp"
            android:background="@drawable/bg_btns"
            android:elevation="10dp"
            android:fontFamily="@font/font_four"
            android:text="Saveing"
            android:textAllCaps="false"
            android:textColor="@color/blue_white"
            android:textFontWeight="800"
            android:textSize="20sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/birthday_edit" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>