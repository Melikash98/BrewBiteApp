<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".CartShoppListActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_title_shopp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:padding="5dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/icon_cart_title"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:src="@drawable/add_item"
            android:tint="@color/dark_brown"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="MissingConstraints,UseAppTint" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:fontFamily="@font/font_two"
            android:text="@string/title_shopp_list"
            android:textColor="@color/color_two"
            android:textFontWeight="900"
            android:textSize="24sp"
            app:layout_constraintBottom_toBottomOf="@id/icon_cart_title"
            app:layout_constraintStart_toEndOf="@id/icon_cart_title"
            app:layout_constraintTop_toTopOf="@id/icon_cart_title" />

    </androidx.constraintlayout.widget.ConstraintLayout>
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginVertical="20dp"
        android:paddingBottom="50dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_title_shopp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="200dp">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="200dp">
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/card_list_shopp_items"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="20dp"
                    android:paddingBottom="200dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
    </ScrollView>


    <TextView
        android:id="@+id/empty_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="90dp"
        android:alpha=".2"
        android:fontFamily="@font/font_three"
        android:text="Shopp List Is Empty"
        android:textAlignment="center"
        android:textAllCaps="false"
        android:textColor="@color/color_one"
        android:textFontWeight="900"
        android:textSize="28sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layout_title_shopp" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="490dp"
        android:background="@drawable/cart_list_bg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/line_cart_list"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:src="@drawable/line_progress"
            android:tint="@color/dark_brown"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="UseAppTint" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/discount_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="0dp"
            android:layout_marginTop="40dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.melikash98.editify.CustomInputEdit
                android:id="@+id/discount_number"
                android:layout_width="350dp"
                android:layout_height="wrap_content"
                android:singleLine="false"
                android:textFontWeight="800"
                app:activeBackground="@drawable/input_active"
                app:hintActiveColor="@color/brown"
                app:hintBackgroundColor="#E4D7CA"
                app:hintColor="@color/gray"
                app:hintFamily="@font/font_three"
                app:hintIcon="@drawable/discount_icon"
                app:hintSize="13sp"
                app:hintText="@string/discount"
                app:inactiveBackground="@drawable/input_inactive"
                app:inputColor="@color/black"
                app:inputFamily="@font/font_three"
                app:inputSingleLine="true"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:textColor="@color/black"
                tools:ignore="MissingConstraints" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/discountBtn"
                android:layout_width="85dp"
                android:layout_height="40dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="30dp"
                android:background="@drawable/bg_btns"
                android:drawablePadding="0dp"
                android:drawableTint="@color/blue_white"
                android:fontFamily="@font/font_one"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:text="@string/apply"
                android:textAlignment="center"
                android:textAllCaps="false"
                android:textColor="@color/blue_white"
                android:textFontWeight="800"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/discount_number"
                app:layout_constraintEnd_toEndOf="@id/discount_number"
                app:layout_constraintTop_toTopOf="@id/discount_number"
                tools:ignore="MissingConstraints" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/main_factor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/discount_layout">
            <LinearLayout
                android:id="@+id/title_name_checkout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="50dp"
                android:orientation="vertical"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/font_seven"
                    android:text="@string/subtotal"
                    android:textAlignment="center"
                    android:textColor="@color/dark_brown"
                    android:textFontWeight="800"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/font_seven"
                    android:text="@string/free_delivery"
                    android:textAlignment="center"
                    android:textColor="@color/dark_brown"
                    android:textFontWeight="800"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/font_seven"
                    android:text="@string/total_tax"
                    android:textAlignment="center"
                    android:textColor="@color/dark_brown"
                    android:textFontWeight="800"
                    android:textSize="18sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="50dp"
                android:layout_marginEnd="40dp"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/dollar"
                        android:tint="@color/dark_brown"
                        tools:ignore="UseAppTint" />

                    <TextView
                        android:id="@+id/subtotalNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/font_seven"
                        android:text="20000"
                        android:textAlignment="center"
                        android:textColor="@color/dark_brown"
                        android:textFontWeight="800"
                        android:textSize="18sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/dollar"
                        android:tint="@color/dark_brown"
                        tools:ignore="UseAppTint" />

                    <TextView
                        android:id="@+id/free_delivery_number"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/font_seven"
                        android:text="4000"
                        android:textAlignment="center"
                        android:textColor="@color/dark_brown"
                        android:textFontWeight="800"
                        android:textSize="18sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/dollar"
                        android:tint="@color/dark_brown"
                        tools:ignore="UseAppTint" />

                    <TextView
                        android:id="@+id/total_tax_number"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/font_seven"
                        android:text="10"
                        android:textAlignment="center"
                        android:textColor="@color/dark_brown"
                        android:textFontWeight="800"
                        android:textSize="18sp" />
                </LinearLayout>

            </LinearLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>

        <View
            android:id="@+id/line_factor"
            android:layout_width="300dp"
            android:layout_height="2dp"
            android:layout_marginStart="50dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="50dp"
            android:background="@color/gray"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/main_factor"
            app:layout_goneMarginTop="10dp" />
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/total_main"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/line_factor">
            <TextView
                android:id="@+id/totalTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="50dp"
                android:fontFamily="@font/font_seven"
                android:text="@string/total"
                android:textAlignment="center"
                android:textColor="@color/dark_brown"
                android:textFontWeight="800"
                android:textSize="18sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="50dp"
                android:orientation="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/totalTitle">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/dollar"
                    android:tint="@color/dark_brown"
                    tools:ignore="UseAppTint" />

                <TextView
                    android:id="@+id/total_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/font_seven"
                    android:text="20000"
                    android:textAlignment="center"
                    android:textColor="@color/dark_brown"
                    android:textFontWeight="800"
                    android:textSize="18sp" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/checkoutBtn"
            android:layout_width="250dp"
            app:layout_constraintTop_toBottomOf="@id/total_main"
            android:layout_height="50dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="5dp"
            android:drawablePadding="0dp"
            android:paddingStart="40dp"
            android:paddingEnd="40dp"
            android:drawableTint="@color/blue_white"
            android:background="@drawable/bg_btns"
            android:text="@string/checkout"
            android:textAllCaps="false"
            android:textAlignment="center"
            android:textSize="18sp"
            android:textFontWeight="800"
            android:textColor="@color/blue_white"
            android:fontFamily="@font/font_one"/>


    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.melikash98.morphnavbar.MorphNavBar
        android:id="@+id/morphShoppList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:lbv_activeIconColor="@color/blue_white"
        app:lbv_badgeBackgroundColor="@color/dark_brown"
        app:lbv_badgeTextColor="@color/white"
        app:lbv_badgeTextSize="8sp"
        app:lbv_barColor="@color/white"
        app:lbv_barHeight="80dp"
        app:lbv_barSideMargin="0dp"
        app:lbv_inactiveIconColor="@color/gray"
        app:lbv_itemIconSize="28dp"
        app:lbv_labelFontFamily="@font/font_three"
        app:lbv_labelTextSize="12sp"
        app:lbv_selectedColor="@color/dark_brown"
        app:lbv_showLabelOnlyOnSelected="true"
        app:lbv_unselectedColor="@color/gray" />
</androidx.constraintlayout.widget.ConstraintLayout>
