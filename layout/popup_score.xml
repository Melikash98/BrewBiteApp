<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <pl.droidsonroids.gif.GifImageView
        android:id="@+id/iconScore"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="20dp"
        android:src="@drawable/sad"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:elevation="10dp"/>
    <androidx.cardview.widget.CardView
        android:id="@+id/card_dialog"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="20dp"
        app:cardElevation="5dp"
        app:cardUseCompatPadding="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/iconScore"
        android:layout_marginTop="50dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="10dp"
            android:paddingRight="30dp">
            <TextView
                android:id="@+id/name_item_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:text="Name Item"
                android:layout_marginTop="55dp"
                android:textSize="18sp"
                android:textFontWeight="900"
                android:textDirection="ltr"
                android:layout_marginStart="30dp"
                android:textColor="@color/black"
                android:textAlignment="center"
                android:fontFamily="@font/font_welcome"/>
            <TextView
                android:id="@+id/description_score"
                android:layout_width="290dp"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginStart="20dp"
                app:layout_constraintTop_toBottomOf="@id/name_item_score"
                android:layout_marginTop="15dp"
                android:text="@string/description_score"
                android:textAlignment="center"
                android:textColor="@color/black"
                android:textDirection="ltr"
                android:textFontWeight="600"
                android:textSize="17sp"
                android:fontFamily="@font/font_three"/>
            <LinearLayout
                android:layout_marginTop="9dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/description_score"
                android:id="@+id/scoreBox">
                <ImageView
                    android:id="@+id/score_one"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/star_notactive"
                    android:backgroundTint="@color/gold"/>
                <ImageView
                    android:id="@+id/score_two"
                    android:layout_marginStart="5dp"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/star_notactive"
                    android:backgroundTint="@color/gold"/>
                <ImageView
                    android:id="@+id/score_three"
                    android:layout_marginStart="5dp"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/star_notactive"
                    android:backgroundTint="@color/gold"/>
                <ImageView
                    android:id="@+id/score_four"
                    android:layout_marginStart="5dp"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/star_notactive"
                    android:backgroundTint="@color/gold"/>
                <ImageView
                    android:id="@+id/score_five"
                    android:layout_marginStart="5dp"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/star_notactive"
                    android:backgroundTint="@color/gold"/>
            </LinearLayout>
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/subScore"
                android:layout_width="250dp"
                android:layout_marginTop="10dp"
                android:elevation="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/scoreBox"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:text="@string/submit"
                android:textSize="18sp"
                android:textFontWeight="700"
                android:textDirection="ltr"
                android:textColor="@color/blue_white"
                android:textAlignment="center"
                android:fontFamily="@font/font_three"
                android:textAllCaps="false"
                android:background="@drawable/bg_btns"
                app:layout_constraintBottom_toBottomOf="parent"
                android:layout_marginBottom="20dp"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>