<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="150dp"
    android:layout_height="150dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    android:layout_marginTop="36dp"
    android:layout_marginStart="10dp"
    android:layout_marginEnd="10dp"
    app:cardCornerRadius="7dp"
    android:background="@drawable/border_explore_background_item"
    android:backgroundTint="@color/white"
    app:cardElevation="0dp">
   <androidx.constraintlayout.widget.ConstraintLayout
       android:id="@+id/real_all_card"
       android:layout_width="match_parent"
       android:visibility="visible"
       android:layout_height="match_parent">
       <ImageView
           android:id="@+id/img_items_explore"
           android:layout_width="match_parent"
           android:layout_height="match_parent"
           android:cropToPadding="true"
           android:scaleType="fitXY"
           android:src="@drawable/cake1_0" />
       <View
           android:layout_width="match_parent"
           android:layout_height="match_parent"
           android:background="#000000"
           android:alpha="0.4"/>
       <androidx.constraintlayout.widget.ConstraintLayout
           android:layout_width="match_parent"
           android:layout_height="match_parent">
           <ImageView
               android:id="@+id/favorit_all_item_explore"
               android:layout_width="20dp"
               android:layout_height="20dp"
               android:background="@drawable/favorite"
               android:backgroundTint="@color/blue_white"
               android:layout_margin="10dp"
               app:layout_constraintStart_toStartOf="parent"
               app:layout_constraintTop_toTopOf="parent"/>
           <androidx.constraintlayout.widget.ConstraintLayout
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               app:layout_constraintEnd_toEndOf="parent"
               app:layout_constraintTop_toTopOf="@id/favorit_all_item_explore"
               app:layout_constraintBottom_toBottomOf="@id/favorit_all_item_explore"
               android:layout_marginEnd="10dp">
               <ImageView
                   android:id="@+id/star_percent_explore_icon"
                   android:layout_width="18dp"
                   android:layout_height="18dp"
                   android:backgroundTint="@color/gold"
                   android:background="@drawable/star"/>
               <TextView
                   android:id="@+id/explore_percent_number_all_item"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:text="3.5"
                   android:fontFamily="@font/font_one"
                   android:textColor="@color/blue_white"
                   android:layout_marginStart="5dp"
                   app:layout_constraintTop_toTopOf="@id/star_percent_explore_icon"
                   app:layout_constraintBottom_toBottomOf="@id/star_percent_explore_icon"
                   app:layout_constraintStart_toEndOf="@id/star_percent_explore_icon"
                   android:textFontWeight="700"
                   android:textSize="14sp"/>
           </androidx.constraintlayout.widget.ConstraintLayout>
           <TextView
               android:id="@+id/explore_name_all_item"
               android:layout_width="110dp"
               android:layout_height="wrap_content"
               android:text="@string/item_name_explore"
               android:textAlignment="center"
               android:textSize="12sp"
               app:layout_constraintStart_toStartOf="parent"
               app:layout_constraintEnd_toEndOf="parent"
               app:layout_constraintTop_toTopOf="parent"
               app:layout_constraintBottom_toBottomOf="parent"
               android:textFontWeight="600"
               android:textColor="@color/blue_white"
               android:fontFamily="@font/font_name"/>
           <androidx.constraintlayout.widget.ConstraintLayout
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:id="@+id/explore_all_price_layout"
               app:layout_constraintStart_toStartOf="parent"
               app:layout_constraintBottom_toBottomOf="parent"
               android:layout_marginBottom="5dp"
               android:layout_marginStart="15dp">
               <ImageView
                   android:id="@+id/icon_dollar_explore_all_item"
                   android:layout_width="18dp"
                   android:layout_height="18dp"
                   android:background="@drawable/dollar"
                   android:backgroundTint="@color/blue_white"
                   app:layout_constraintBottom_toBottomOf="parent"
                   app:layout_constraintStart_toStartOf="parent"
                   app:layout_constraintTop_toTopOf="parent" />
               <TextView
                   android:id="@+id/price_number_explore_all_item"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:layout_marginStart="0dp"
                   android:fontFamily="@font/font_name"
                   android:text="500"
                   android:textColor="@color/blue_white"
                   android:textFontWeight="600"
                   android:textSize="16sp"
                   app:layout_constraintBottom_toBottomOf="@id/icon_dollar_explore_all_item"
                   app:layout_constraintStart_toEndOf="@id/icon_dollar_explore_all_item"
                   app:layout_constraintTop_toTopOf="@id/icon_dollar_explore_all_item" />
           </androidx.constraintlayout.widget.ConstraintLayout>
           <androidx.constraintlayout.widget.ConstraintLayout
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               app:layout_constraintEnd_toEndOf="parent"
               app:layout_constraintTop_toTopOf="@id/explore_all_price_layout"
               app:layout_constraintBottom_toBottomOf="@id/explore_all_price_layout"
               android:layout_marginEnd="10dp">
               <ImageView
                   android:id="@+id/add_explore_all_btn"
                   android:layout_width="20dp"
                   android:layout_height="20dp"
                   android:background="@drawable/add_item"
                   android:backgroundTint="@color/blue_white"
                   app:layout_constraintStart_toStartOf="parent"/>
               <ImageView
                   android:id="@+id/show_explore_all_btn"
                   android:layout_width="20dp"
                   android:layout_height="20dp"
                   android:background="@drawable/arrow_right"
                   android:backgroundTint="@color/blue_white"
                   app:layout_constraintStart_toEndOf="@id/add_explore_all_btn"
                   app:layout_constraintTop_toTopOf="@id/add_explore_all_btn"
                   app:layout_constraintBottom_toBottomOf="@id/add_explore_all_btn"
                   android:layout_marginStart="7dp"/>
           </androidx.constraintlayout.widget.ConstraintLayout>


       </androidx.constraintlayout.widget.ConstraintLayout>
   </androidx.constraintlayout.widget.ConstraintLayout>
    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/shimmer_all_card"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/border_explore_background_item"
            android:padding="6dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <View
                android:id="@+id/shimmer_name_coffee"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/loading_back_re"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_marginStart="3dp"
                app:layout_constraintTop_toTopOf="parent"/>


            <View
                android:id="@+id/shimmer_percent_coffee"
                android:layout_width="100dp"
                android:layout_height="30dp"
                android:background="@drawable/loading_back_re"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <View
                android:id="@+id/shimmer_price_coffee"
                android:layout_width="40dp"
                android:layout_height="15dp"
                android:layout_marginTop="16dp"
                android:layout_marginStart="10dp"
                android:layout_marginBottom="11dp"
                android:background="@drawable/loading_back_re"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />
            <View
                android:id="@+id/shimmer_add_coffee"
                android:layout_width="50dp"
                android:layout_height="17dp"
                android:layout_marginTop="3dp"
                android:layout_marginEnd="-3dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/loading_back_re"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
            <View
                android:id="@+id/shimmer_show_coffee"
                android:layout_width="56dp"
                android:layout_height="26dp"
                android:layout_marginEnd="0dp"
                android:background="@drawable/loading_back_re"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/shimmer_price_coffee"
                app:layout_constraintBottom_toBottomOf="@id/shimmer_price_coffee"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.facebook.shimmer.ShimmerFrameLayout>
</androidx.cardview.widget.CardView>